# Backend provider: nself | supabase | nhost | bolt
NEXT_PUBLIC_BACKEND_PROVIDER=nself

# nSelf backend URLs (used when BACKEND_PROVIDER=nself)
NEXT_PUBLIC_NSELF_GRAPHQL_URL=https://api.local.nself.org/v1/graphql
NEXT_PUBLIC_NSELF_GRAPHQL_WS_URL=wss://api.local.nself.org/v1/graphql
NEXT_PUBLIC_NSELF_AUTH_URL=https://auth.local.nself.org
NEXT_PUBLIC_NSELF_STORAGE_URL=https://storage.local.nself.org
NEXT_PUBLIC_NSELF_REALTIME_URL=wss://api.local.nself.org/v1/graphql
NEXT_PUBLIC_NSELF_FUNCTIONS_URL=https://functions.local.nself.org

# App config
NEXT_PUBLIC_APP_NAME=ɳTask
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENVIRONMENT=local
NEXT_PUBLIC_TABLE_PREFIX=app
