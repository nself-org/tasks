{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ɳTasks",
  "version": "0.1.0",
  "identifier": "org.nself.tasks",
  "build": {
    "frontendDist": "../../../out",
    "devUrl": "http://localhost:3017"
  },
  "app": {
    "windows": [
      {
        "title": "ɳTasks",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "signingIdentity": null,
      "entitlements": null,
      "urlSchemes": ["ntasks"]
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": null
    },
    "linux": {
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": true,
      "endpoints": ["https://nself.org/api/desktop/updates/{{target}}/{{arch}}/{{current_version}}"],
      "dialog": true,
      "pubkey": ""
    },
    "deep-link": {
      "mobile": [],
      "desktop": ["ntasks://*"]
    },
    "windowState": {
      "stateFlags": "SIZE | POSITION | MAXIMIZED | FULLSCREEN | DECORATIONS"
    }
  }
}
